#!/bin/bash
# Auto-format staged Go files with gofmt before each commit.
staged=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$')
if [ -n "$staged" ]; then
    echo "$staged" | xargs gofmt -w
    echo "$staged" | xargs git add
fi

# Run golangci-lint on all Go files.
golangci-lint run ./...
